<?xml version="1.0"?>
<config xmlns:xc="urn:ietf:params:xml:ns:netconf:base:1.0">
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">
    
    <!-- Hostname configuration -->
    <hostname>NETCONF-Router-PE</hostname>
    
    <!-- Interface configurations -->
    <interface>
      <GigabitEthernet>
        <name>1</name>
        <description>Management Interface - Configured by Ansible NETCONF</description>
        <ip>
          <address>
            <primary>
              <address>10.255.255.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
        <no>
          <shutdown/>
        </no>
      </GigabitEthernet>
      
      <GigabitEthernet>
        <name>2</name>
        <description>Secondary Interface - Configured by Ansible NETCONF</description>
        <ip>
          <address>
            <primary>
              <address>192.168.1.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
        <no>
          <shutdown/>
        </no>
      </GigabitEthernet>
      
      <Loopback>
        <name>0</name>
        <description>Loopback Interface for OSPF</description>
        <ip>
          <address>
            <primary>
              <address>172.16.1.1</address>
              <mask>255.255.255.255</mask>
            </primary>
          </address>
        </ip>
      </Loopback>
    </interface>
    
    <!-- OSPF routing configuration -->
    <router>
      <ospf>
        <id>1</id>
        <network>
          <ip>10.255.255.0</ip>
          <wildcard>0.0.0.255</wildcard>
          <area>0</area>
        </network>
        <network>
          <ip>192.168.1.0</ip>
          <wildcard>0.0.0.255</wildcard>
          <area>0</area>
        </network>
        <network>
          <ip>172.16.1.0</ip>
          <wildcard>0.0.0.255</wildcard>
          <area>0</area>
        </network>
      </ospf>
    </router>
    
  </native>
</config>
